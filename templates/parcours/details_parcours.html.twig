{% extends 'base.html.twig' %}

{% block title %}Hello ParcoursController!{% endblock %}

{% block body %}

<div class="sidebar">
    <ul>
        <li><a href="{{ path('app_home') }}">Accueil</a></li>
        <li><a href="{{ path('app_race') }}">course</a></li>
        <li><a href="{{ path('app_parcours') }}">parcours</a></li>
        <li><a href="{{ path('app_beacon') }}">balise</a></li>
    </ul>
</div>
</br>
</br>
</br>
</br>
{% for beacon in beacons %}
    <li>{{ beacon.name }} {{ beacon.isPlaced }}</li></br>
{% else %}
    <li>Aucune balise associée pour cette map</li>
{% endfor %}
</br>
</br> 
{% if ready == true %}
    <form method="post" action="{{ path('app_map_ready', {id: map.id}) }}">
    <button type="submit">Map Ready</button>
    </form>

{% endif %}
</br>
</br>
<div class="content">
    {{ ux_map(
        center: [51.5074, 0.1278],
        zoom: 3,
        markers: [
            { position: [51.5074, 0.1278], title: 'London' },
            { position: [48.8566, 2.3522], title: 'Paris' },
            { position: [40.7128, -74.0060], title: 'New York', infoWindow: { content: 'Welcome to <b>New York</b>' } }
        ],
        fitBoundsToMarkers: true,
        attributes: {
            style: 'height: 800px; width: 100%; border: 4px solid red; margin-block: 10vh;'
        }
    ) }}
</div>
{% endblock %}
