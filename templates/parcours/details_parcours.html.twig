{% extends 'base.html.twig' %}

{% block title %}Hello ParcoursController!{% endblock %}

{% block body %}

<div class="navbar">

    <div class="nav-left">
        <div class="logo">e-CO</div>

        <ul class="nav-links">
            <li><a href="{{ path('app_race') }}">Courses</a></li>
            <li>
                <a href="{{ path('app_parcours') }}"
                   class="{{ app.request.attributes.get('_route') == 'app_parcours' ? 'active' : '' }}">
                   Parcours
                </a>
            </li>
        </ul>
    </div>

    <div class="nav-right">
        <a href="#" class="btn-logout">Déconnexion</a>
        <span class="gear">⚙</span>
    </div>

</div>
<div class="container">

    <div class="topbar">
        <h2>{{ map.NameMap }}</h2>

        {% if ready %}
            <form method="post" action="{{ path('app_map_ready', {id: map.id}) }}">
                <button class="btn">Map Ready</button>
            </form>
        {% endif %}
    </div>

    <div class="layout">

        <!-- SIDEBAR -->
        <div class="sidebar">
            <h3>Balises</h3>

            {% for beacon in beacons %}
                <div class="beacon-card">
                    <div class="beacon-title">
                        {{ beacon.name }}
                    </div>

                    <div class="beacon-info">
                        <span class="badge {{ beacon.status }}">
                            {{ beacon.status }}
                        </span>

                        <span class="placed {{ beacon.isPlaced ? 'ok' : 'ko' }}">
                            {{ beacon.isPlaced ? 'Placée' : 'Non placée' }}
                        </span>
                    </div>
                </div>
            {% endfor %}
        </div>

        <!-- MAP -->
        <div class="map-container">
            <div id="map"></div>
        </div>

    </div>

<script>
    const markers = {{ markers|json_encode|raw }};
    const path = {{ path|json_encode|raw }};
</script>

<script>
function initMap() {
    const center = markers.length > 0
        ? { lat: markers[0].lat, lng: markers[0].lng }
        : { lat: 48.8566, lng: 2.3522 };

    const map = new google.maps.Map(document.getElementById("map"), {
        zoom: 14,
        center: center
    });

    // MARKERS
    markers.forEach(marker => {
        let icon;

        switch (marker.type) {
            case 'depart':
                icon = "http://maps.google.com/mapfiles/ms/icons/green-dot.png";
                break;
            case 'arrivee':
                icon = "http://maps.google.com/mapfiles/ms/icons/red-dot.png";
                break;
            default:
                icon = "http://maps.google.com/mapfiles/ms/icons/orange-dot.png";
        }

        new google.maps.Marker({
            position: { lat: marker.lat, lng: marker.lng },
            map: map,
            title: marker.title,
            icon: icon
        });
    });

    // LIGNE (parcours)
    const flightPath = new google.maps.Polyline({
        path: path,
        geodesic: true,
        strokeColor: "#5f744d",
        strokeOpacity: 1.0,
        strokeWeight: 3,
    });

    flightPath.setMap(map);
}
</script>

<script async
    src="https://maps.googleapis.com/maps/api/js?key={{ google_maps_api_key }}&callback=initMap">
</script>
</div>
{% endblock %}
