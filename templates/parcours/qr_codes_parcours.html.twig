{% extends 'base.html.twig' %}
{% block title %}Parcours{% endblock %}

{% block body %}
{% include 'partials/_main_nav.html.twig' %}

<div class="container">
    <div class="page-card">
        <div class="topbar print-hide">
            <div>
                <h1>QR codes du parcours {{ map.nameMap }}</h1>
                <p class="subtitle">Imprimez cette page puis choisissez "Enregistrer au format PDF".</p>
            </div>
            <div class="actions">
                <a href="{{ path('app_parcours') }}" class="btn">Retour</a>
                <button type="button" class="btn edit" onclick="window.print()">Télécharger en PDF</button>
            </div>
        </div>

        <div class="qr-grid">
            {% for item in qrCodes %}
                <article class="qr-card">
                    <h3>{{ item.beacon.name }}</h3>
                    <p class="qr-meta">Type : {{ item.beacon.status|capitalize }}</p>
                    <img src="{{ item.qr }}" alt="QR code {{ item.beacon.name }}">
                    <p class="qr-helper">Scannez pour valider le passage.</p>
                </article>
            {% else %}
                <div class="empty-state">Aucun QR code disponible pour ce parcours.</div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}