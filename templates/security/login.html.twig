{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-shell">
        <section class="auth-visual">
            <h2>Orientation Manager</h2>
            <p>Préparez vos parcours, suivez les coureurs et gardez le contrôle sur toutes les balises de terrain.</p>
        </section>

        <section class="auth-card">
            <h1>Connexion</h1>
            <p class="lead">Accès sécurisé à votre espace d'administration</p>

            <form method="post">
                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                {% if app.user %}
                    <div class="alert">
                        Connecté en tant que {{ app.user.userIdentifier }},
                        <a href="{{ logout_path() }}">se déconnecter</a>.
                    </div>
                {% endif %}

                <label for="username">Adresse email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>

                <label for="password">Mot de passe</label>
                <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <button class="btn btn-lg" type="submit">Se connecter</button>
            </form>
        </section>
    </div>
</div>
{% endblock %}
