{% extends 'base.html.twig' %}

{% block title %}Détail course{% endblock %}

{% block body %}
<div class="navbar">
    <div class="nav-left">
        <a href="{{ path('app_race') }}" class="logo">e-CO</a>
        <ul class="nav-links">
            <li><a href="{{ path('app_race') }}" class="active">Courses</a></li>
            <li><a href="{{ path('app_parcours') }}">Parcours</a></li>
        </ul>
    </div>
    <div class="nav-right">
        <a href="{{ path('app_logout') }}" class="btn-logout">Déconnexion</a>
        <span class="gear">⚙</span>
    </div>
</div>

{% set finishers = 0 %}
{% set bestTime = null %}
{% for result in results %}
    {% if result.time %}
        {% set finishers = finishers + 1 %}
        {% if bestTime is null or result.time < bestTime %}
            {% set bestTime = result.time %}
        {% endif %}
    {% endif %}
{% endfor %}

<div class="container">
    <div class="page-card">
        <div class="topbar">
            <div>
                <h1>Classement de la course</h1>
                <p class="subtitle">Code course : <span class="race-code">{{ race.codeRace }}</span> - Liste des runners et accès au détail de leur trace GPS.</p>
            </div>
            <a href="{{ path('app_race') }}" class="btn edit">Retour aux courses</a>
        </div>

        <div class="race-layout">
            <div class="table-container">
                <table class="styled-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Runner</th>
                            <th>Temps</th>
                            <th>Statut</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for result in results %}
                            <tr>
                                <td>{{ loop.index }}</td>
                                <td class="runner-name">{{ result.runner.name }}</td>
                                <td>
                                    {% if result.time %}
                                        {{ result.time }} s
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>
                                    {% if result.time %}
                                        <span class="chip ok">Terminé</span>
                                    {% else %}
                                        <span class="chip ko">Non terminé</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('app_runner_details', {id: result.runner.id}) }}" class="btn">Voir détail</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5">
                                    <div class="empty-state">Aucun runner inscrit pour cette course.</div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <aside class="race-sidebar">
                <div class="stat-card">
                    <p class="stat-label">Code course</p>
                    <p class="stat-value race-code-value">{{ race.codeRace }}</p>
                </div>
                <div class="stat-card">
                    <p class="stat-label">Runners</p>
                    <p class="stat-value">{{ results|length }}</p>
                </div>
                <div class="stat-card">
                    <p class="stat-label">Arrivés</p>
                    <p class="stat-value">{{ finishers }}</p>
                </div>
                <div class="stat-card">
                    <p class="stat-label">Meilleur temps</p>
                    <p class="stat-value">
                        {% if bestTime is not null %}
                            {{ bestTime }} s
                        {% else %}
                            —
                        {% endif %}
                    </p>
                </div>
            </aside>
        </div>
    </div>
</div>
{% endblock %}