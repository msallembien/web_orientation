{% extends 'base.html.twig' %}

{% block title %}Créer une course{% endblock %}

{% block body %}

<div class="container">
    <h1>Créer une course</h1>

    <form method="post">
        
        <label>Choisir un parcours (READY uniquement)</label>

        <select name="map_id" required>
            {% for map in maps %}
                <option value="{{ map.id }}">
                    {{ map.nameMap }}
                </option>
            {% else %}
                <option disabled>Aucun parcours READY</option>
            {% endfor %}
        </select>

        <br><br>

        <button class="btn edit">Créer la course</button>

    </form>
</div>

{% endblock %}